# Copy this to .env.local for local dev, and add the same values in Vercel
# Project Settings -> Environment Variables for production.

# Where quote requests get emailed. Required.
QUOTE_RECIPIENT_EMAIL=hello@ecoboom.org

# Resend API key for outbound email. Get one at resend.com.
# If empty, the /api/quote route will log submissions to the server console
# instead of sending email (useful for local dev).
RESEND_API_KEY=

# Optional: the "from" address Resend sends from. Must be a verified domain.
QUOTE_FROM_EMAIL=quotes@ecoboom.org
